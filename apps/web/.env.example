# Taste Lab web env template.
# Copy this file to apps/web/.env.local before running npm run dev:
#   cp apps/web/.env.example apps/web/.env.local
#
# The active Next.js app runs from apps/web, so a repo-root .env.local is not
# the expected runtime env file for the web app.

# Local data directory. Relative paths resolve from the web app process
# directory, so this defaults to apps/web/.local-data when running the workspace.
DATA_DIR=.local-data

# Where the Next.js /api/gaze/* proxy forwards. Leave at the default for
# local dev (the FastAPI backend in apps/api/ binds to 127.0.0.1:8000).
# Point this at a remote URL when deploying the model behind a private
# network or a managed inference endpoint.
GAZE_API_URL=http://127.0.0.1:8000

# OpenAI key for GPT-5.5 agent planning and GPT Image reference generation.
# Leave blank to use deterministic local/mock fallbacks.
OPENAI_API_KEY=

# Optional GPT Image model override. Defaults to gpt-image-2.
OPENAI_IMAGE_MODEL=gpt-image-2
# Optional GPT Image latency/quality knobs for agent reference generation.
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=medium

# Optional foundation-model endpoint for attention/evaluation only.
# Leave blank for mock attention/evaluation.
FOUNDATION_MODEL_URL=
FOUNDATION_MODEL_API_KEY=
