# Gaze Prediction API env template.
# Copy to apps/api/.env and source it before launching `./apps/api/run_dev.sh`,
# or just `export` the variables you want to override:
#
#   cp apps/api/.env.example apps/api/.env
#   set -a; source apps/api/.env; set +a
#   ./apps/api/run_dev.sh

# Path to the .pt checkpoint to load. Resolved relative to the repo root.
GAZE_CHECKPOINT=model/checkpoints/gaze_epoch250.pt

# Device to run inference on. "auto" picks cuda → mps → cpu.
MODEL_DEVICE=auto

# uvicorn bind host/port.
API_HOST=127.0.0.1
API_PORT=8000

# CORS allow-list for direct browser calls. The Next.js proxy at
# apps/web/app/api/gaze/[action]/route.ts is server-side, so it doesn't
# care about CORS — but if you POST to FastAPI directly from the browser,
# add your origin here.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Reject uploads larger than this (bytes). Default: 25 MiB.
MAX_UPLOAD_BYTES=26214400

# Python logging level for the gaze_api logger (DEBUG/INFO/WARNING/ERROR).
LOG_LEVEL=INFO

# Used by run_dev.sh to pick the Python binary; ignored by the API itself.
# Set this when your conda env's `python` isn't on PATH.
# PYTHON=/opt/anaconda3/envs/hacktech26/bin/python
